# =============================================================
# Python AI Server 환경변수 설정 (Ollama / RunPod 기반)
# =============================================================
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
#   cp .env.example .env
#
# 본 프로젝트의 기본 LLM 분석 엔진은 자체 RunPod/로컬 Ollama 서버입니다.
# Gemini 등 상용 API는 기본 흐름에서 사용하지 않습니다.
# =============================================================

# ── 1. LangGraph 멀티에이전트 엔진 ──────────────────────────
# true:  LangGraph 토론 (BIZ↔LEGAL 라운드 + JUDGE) — 권장
# false: 규칙 기반 분석 (LLM 없이 동작)
USE_LANGGRAPH=true

# ── 2. LLM provider 선택 ────────────────────────────────────
# 기본값: ollama (자체 서버). 상용 API는 사용하지 않음.
AI_PROVIDER=ollama

# ── 3. Ollama 서버 설정 (AI_PROVIDER=ollama 시 필수) ────────
# RunPod proxy URL 또는 로컬 Ollama 서버 base URL.
# 예 1) RunPod (HTTPS proxy):
#       OLLAMA_BASE_URL=https://abcd1234-11434.proxy.runpod.net
# 예 2) 로컬:
#       OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# 사용할 모델명 (`ollama list`로 확인). 예: llama3.1:8b, qwen2.5:7b, exaone3.5:7.8b
OLLAMA_MODEL=llama3.1:8b

# 호출 timeout(초) — RunPod 외부 호출 + 토큰 길이 고려해 넉넉히
OLLAMA_TIMEOUT=600

# 일시적 오류(502/503/504/500/429, 네트워크 단절) 재시도 횟수
OLLAMA_MAX_RETRIES=3

# 재시도 backoff (초). RunPod proxy cold-start 대비 첫 대기 길게.
# 실제 대기 = min(BASE * 2^(n-1), MAX) — 예) 2 → 4 → 8 → 16 → 20
OLLAMA_RETRY_BASE_DELAY=2
OLLAMA_RETRY_MAX_DELAY=20

# (선택) /health/ollama deep check timeout(초)
OLLAMA_HEALTH_TIMEOUT=10

# ── 4. 법제처 Open API (RAG evidence 수집) ──────────────────
# 발급: https://open.law.go.kr → 회원가입 → API 키 신청
# 미설정 시 evidence 수집이 건너뛰어지고 빈 배열이 반환됩니다.
LAW_API_KEY=

# ── 5. (선택) Chroma DB 경로 ────────────────────────────────
# CHROMA_DB_DIR=./chroma_db

# ── 6. (선택) 토론 라운드 수 ────────────────────────────────
# LANGGRAPH_MAX_ROUNDS=2

# =============================================================
# (DEPRECATED / 사용하지 않음) Legacy Gemini fallback
# =============================================================
# 본 프로젝트는 자체 RunPod/Ollama 서버를 LLM provider로 사용합니다.
# 아래 키들은 기본 실행 흐름에 필요하지 않으며, 채우지 않아도 됩니다.
#
# 만약 임시 디버깅 등으로 Gemini를 써야 한다면:
#   1) pip install google-genai>=1.0.0   (의존성 별도 설치)
#   2) AI_PROVIDER=gemini 로 변경
#   3) GEMINI_API_KEY 입력
# 단, 이는 프로젝트 표준 흐름이 아니므로 운영/시연용으로는 사용하지 마세요.
#
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
