# =============================================================
# Python AI Server 환경변수 설정
# =============================================================
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
#   cp .env.example .env
# =============================================================

# ── 1. LangGraph 멀티에이전트 엔진 ──────────────────────────
# true: Gemini + RAG 멀티에이전트 토론 (권장)
# false: 규칙 기반 분석 (Gemini 없이도 동작)
USE_LANGGRAPH=true

# Google Gemini API 키 (USE_LANGGRAPH=true 시 필수)
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── 2. 법제처 Open API (법령·판례 근거 수집) ────────────────
# 발급: https://open.law.go.kr → 회원가입 → API 키 신청
# 미설정 시 evidence 수집이 건너뛰어지고 빈 배열이 반환됩니다
LAW_API_KEY=

# ── 3. 선택 사항 ────────────────────────────────────────────
# Chroma DB 경로 (RAG용, 기본: ./chroma_db)
# CHROMA_DB_DIR=./chroma_db

# 토론 라운드 수 (기본: 2, BIZ↔LEGAL 교대 후 JUDGE 판정)
# LANGGRAPH_MAX_ROUNDS=2

# Gemini 모델 (기본: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Chroma DB 빌드용 법제처 API 키 (LAW_API_KEY와 동일 값 사용 가능)
# MOGL_API_KEY=
