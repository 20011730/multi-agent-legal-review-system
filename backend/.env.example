# =============================================================
# Backend 환경변수 설정
# =============================================================
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
#   cp .env.example .env
# =============================================================

# ── AI 엔진 선택 ────────────────────────────────────────────
# python : 기존 Python FastAPI + LangGraph/Gemini (기본값)
# ollama : Ollama API 직접 호출 (로컬 또는 RunPod)
AI_ENGINE=ollama

# ── Ollama 설정 (AI_ENGINE=ollama 일 때만 사용) ─────────────
# SSH 터널 사용 시 localhost:11434 그대로 사용
# RunPod 직접 연결 시 해당 URL로 변경
OLLAMA_BASE_URL=http://localhost:11434

# Ollama에 설치된 모델명 (ollama list 로 확인)
OLLAMA_MODEL=glm-4.7-flash:q4_K_M

# 모델 응답 타임아웃 (초). 29B 모델은 호출당 90~150초 소요
OLLAMA_TIMEOUT=1500

# ── Python AI 서버 (AI_ENGINE=python 일 때만 사용) ──────────
# AI_SERVER_URL=http://localhost:8001

# ── DB 설정 ─────────────────────────────────────────────────
# DB_URL=jdbc:postgresql://localhost:5432/legalreview
# DB_USERNAME=legalreview
# DB_PASSWORD=legalreview

# ── 법제처 API ──────────────────────────────────────────────
# LAW_API_OC=SangHoon
