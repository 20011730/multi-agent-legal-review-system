# =============================================================
# Python AI Server 환경변수 설정
# =============================================================
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
#   cp .env.example .env
#
# 국가법령정보센터 Open API 키가 없으면 법령/판례 근거 수집이
# 비활성화되며, 분석 결과의 evidences 배열이 빈 값으로 반환됩니다.
# 기존 분석 기능(messages, finalDecision)은 영향 없이 정상 동작합니다.
# =============================================================

# 국가법령정보센터 Open API 인증 키 (OC 파라미터)
# 발급: https://open.law.go.kr → 회원가입 → API 키 신청
# 주의: 발급 시 서버 IP 주소를 등록해야 호출 가능
LAW_API_KEY=

# (선택) 법령 검색 API 기본 URL — 기본값 사용 시 비워두세요
# LAW_API_BASE_URL=http://www.law.go.kr/DRF/lawSearch.do

# (선택) 판례 검색 API 기본 URL — 기본값 사용 시 비워두세요
# CASE_API_BASE_URL=http://www.law.go.kr/DRF/lawSearch.do

# (선택) 판례 전용 API 키 — 미설정 시 LAW_API_KEY를 공유합니다
# CASE_API_KEY=

# =============================================================
# LangGraph 멀티에이전트 엔진 설정 (USE_LANGGRAPH=true 시 필요)
# =============================================================

# LangGraph 엔진 활성화 (true / false)
# false(기본): 규칙 기반 분석 | true: Gemini + RAG 멀티에이전트 토론
USE_LANGGRAPH=false

# Google Gemini API 키 (LangGraph 엔진 사용 시 필수)
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# (선택) Chroma DB 경로 — 기본값: ./chroma_db
# CHROMA_DB_DIR=./chroma_db

# (선택) 토론 라운드 수 — 기본값: 2 (BIZ↔LEGAL 2회 교대 후 JUDGE 판정)
# LANGGRAPH_MAX_ROUNDS=2

# (선택) 법제처 API 키 (Chroma DB 빌드용, LAW_API_KEY와 별도)
# MOGL_API_KEY=
