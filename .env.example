# ─────────────────────────────────────────────────────────────
# 로컬 개발 환경변수 템플릿
#   - 본 파일은 커밋 대상. 실제 값은 .env 파일에 복사 후 수정 (.env는 .gitignore)
#   - 사용 방법:
#       cp .env.example .env
#       vi .env                    # 실제 값 채워넣기
#       ./scripts/start-db.sh
#       ./scripts/start-backend.sh
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL (docker-compose) ──
POSTGRES_DB=legalreview
POSTGRES_USER=legalreview
POSTGRES_PASSWORD=legalreview

# ── Spring Boot DataSource ──
# 컨테이너 외부(호스트)에서 접속하므로 localhost 사용
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/legalreview
SPRING_DATASOURCE_USERNAME=legalreview
SPRING_DATASOURCE_PASSWORD=legalreview

# 호환용(application.yml에서 읽음 — DB_URL/DB_USERNAME/DB_PASSWORD 우선)
DB_URL=jdbc:postgresql://localhost:5432/legalreview
DB_USERNAME=legalreview
DB_PASSWORD=legalreview

# ── 국가법령정보센터 OPEN API ──
# 발급받은 OC 값을 입력. 미설정 시 law_list/law_documents API 수집 비활성.
LAW_API_OC=여기에_본인_OC값_입력

# ── RAG / Chroma ──
# Chroma 컨테이너의 호스트 포트
# (본 프로젝트가 실제 읽는 키는 CHROMA_BASE_URL — application.yml#app.rag.chroma.base-url)
CHROMA_BASE_URL=http://localhost:8000

# RAG 마스터 스위치 — Chroma 사용 시 true 권장.
# (Chroma upsert/query 메서드는 enabled=false면 즉시 빈 결과 반환하여 no-op)
APP_RAG_ENABLED=true

# 개발용 endpoint(/api/rag/*) 활성화. 운영 배포 시 false.
APP_RAG_INGESTION_DEV_ENDPOINT_ENABLED=true

# ── RAG 실험 추적(선택) ──
RAG_EXPERIMENT_ENABLED=false
RAG_EXPERIMENT_TAG=default

# ── RAG top-k(선택) ──
RAG_TOPK_LAW=3
RAG_TOPK_CASE=2

# ── RAG Embedding provider(선택) ──
# simple   : 의존성 0, 한국어 char-ngram hash (현재 default — 검증/시연용)
# external : 외부 HTTP 임베딩 서비스 (예: sentence-transformers/bge-m3)
# e5       : E5 계열 (stub — 향후 fine-tuned model로 교체 예정)
APP_RAG_EMBEDDING_PROVIDER=simple
RAG_EMBEDDING_MODEL=simple-hash-v1
RAG_EMBEDDING_DIM=384
RAG_EMBEDDING_EXTERNAL_URL=http://localhost:9100
RAG_EMBEDDING_EXTERNAL_PATH=/embed
RAG_EMBEDDING_EXTERNAL_TIMEOUT=30

# ── AI 엔진(선택) ──
# python = 외부 FastAPI, ollama = 로컬 ollama 직접 호출
AI_ENGINE=python
AI_SERVER_URL=http://localhost:8001
# Python AI Server HTTP 호출 timeout (초). LangGraph+RunPod/Ollama가 느릴 때 늘릴 것.
# 기본값: 30 / 900 (15분).
AI_CONNECT_TIMEOUT_SECONDS=30
AI_READ_TIMEOUT_SECONDS=900
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=glm-4.7-flash:q4_K_M
